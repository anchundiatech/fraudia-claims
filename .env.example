# ─── XAI (Grok) — agente de IA ──────────────────────────
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-2-latest

# ─── Supabase — esquema actual ───────────────────────────
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-service-role-o-anon-key

# Vista principal (póliza + puntaje total o solo asegurado)
DB_TABLE_SINIESTROS=vPoliza_Puntaje_Total
# Alternativa: DB_TABLE_SINIESTROS=vPoliza_Asegurado

DB_TABLE_ASEGURADO=vPoliza_Asegurado
DB_TABLE_POLIZA_PUNTAJE=POLIZA_PUNTAJE
DB_TABLE_DOCUMENTO=DOCUMENTO
DB_TABLE_SCORE_RIESGO=SCORE_RIESGO

# ─── App ─────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
FRONTEND_URL=http://localhost:3000

# ─── Datos locales (fallback) ────────────────────────────
USE_DATABASE=false
DATASET_PATH=../../data/synthetic/siniestros.csv
